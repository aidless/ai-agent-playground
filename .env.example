# =============================================
# AI Agent Playground Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# =============================================
# LLM Configuration (Choose one)
# =============================================

# Option 1: DeepSeek (Anthropic-compatible)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# Option 2: Anthropic directly
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# =============================================
# Application Settings
# =============================================

# Server
HOST=0.0.0.0
PORT=8501

# Debug mode (true/false)
DEBUG=false

# =============================================
# Security
# =============================================

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Session secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=your-session-secret-here

# =============================================
# Database & Cache
# =============================================

# Vector database (ChromaDB)
CHROMA_PERSIST_DIRECTORY=./data/chroma

# Redis (optional, for distributed caching)
REDIS_URL=redis://localhost:6379/0

# =============================================
# Logging & Monitoring
# =============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log

# OpenTelemetry endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================
# Feature Flags
# =============================================

# Enable/disable features
ENABLE_CACHE=true
ENABLE_TRACING=true
ENABLE_RATE_LIMIT=true

# =============================================
# For Production Deployment
# =============================================

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# Max concurrent requests
MAX_CONCURRENT_REQUESTS=10

# Request timeout (seconds)
REQUEST_TIMEOUT=30