# =============================================
# 🚨 安全警告 🚨
# 1. 永远不要将 .env 文件提交到版本控制
# 2. 使用强随机密钥（示例生成命令见下方）
# 3. 生产环境必须设置所有安全配置
# =============================================
# AI Agent Playground Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# =============================================
# LLM Configuration
# =============================================
# DeepSeek API (Anthropic-compatible)
DEEPSEEK_API_KEY=  # 必填：从 https://platform.deepseek.com 获取
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# =============================================
# 🔐 Security (生产环境必填)
# =============================================
# 生成命令: openssl rand -hex 32
GATEWAY_API_KEY=  # API网关密钥，生产环境必填
IDENTITY_SIGNING_KEY=  # 身份Token签名密钥，生产环境必填
SESSION_SECRET=  # 会话密钥，生产环境必填

# =============================================
# 🌐 CORS (生产环境限制来源)
# =============================================
# 逗号分隔，生产环境不要使用 *
CORS_ORIGINS=https://yourdomain.com

# =============================================
# ⏱️ Rate Limiting
# =============================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================
# 👤 Default Admin Identity
# =============================================
# 生成命令: openssl rand -hex 16
DEFAULT_ADMIN_API_KEY=

# =============================================
# Application Settings
# =============================================
HOST=0.0.0.0
PORT=8501
DEBUG=false
APP_ENV=development  # development | testing | production

# =============================================
# Database & Cache
# =============================================
CHROMA_PERSIST_DIRECTORY=./data/chroma
REDIS_URL=redis://localhost:6379/0

# =============================================
# Logging & Monitoring
# =============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================
# Feature Flags
# =============================================
ENABLE_CACHE=true
ENABLE_TRACING=true
ENABLE_RATE_LIMIT=true
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30
